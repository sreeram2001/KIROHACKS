{
  "enabled": true,
  "name": "TypeScript Check on Save",
  "description": "Runs TypeScript type checking when any extension source file is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "extension/src/**/*.ts",
      "extension/src/**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd extension && npx tsc --noEmit 2>&1 | tail -5"
  }
}